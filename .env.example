# Copy to apps/mobile/.env (or repo root) or export before `expo start`
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# Same as anon key if you prefer this name (dashboard “API key”):
# EXPO_PUBLIC_SUPABASE_KEY=your_anon_key

# Optional: release/build metadata for EAS (apps/mobile/app.config.js)
# APP_VERSION=1.0.0
# IOS_BUILD_NUMBER=1
# ANDROID_VERSION_CODE=1
# IOS_BUNDLE_IDENTIFIER=com.gymbros.app
# ANDROID_PACKAGE=com.gymbros.app
# EAS_PROJECT_ID=00000000-0000-0000-0000-000000000000

# Optional: direct Postgres (psql, GUI tools). Password = Database password in Supabase dashboard.
# Not used by the Expo app. Never commit a real password.
# DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Optional: only for `npm run create-test-user` (never use in the Expo app or commit real keys)
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret
# TEST_USER_EMAIL=test@gymbros.local
# TEST_USER_PASSWORD=testtest12
